PORT=5000
NODE_ENV=development
# Comma-separated origins. Required when NODE_ENV=production.
FRONTEND_URL=http://localhost:5173
JSON_LIMIT=16kb
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000

ETHERSCAN_API_KEY=
ETHERSCAN_CHAIN_ID=1
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com

# Optional server-side API key used to resolve Unstoppable Domains.
UNSTOPPABLE_API_KEY=

# Maximum wallet analyses allowed per client IP during the configured window.
WALLET_RATE_LIMIT_MAX=10
WALLET_RATE_LIMIT_WINDOW_MS=60000
DOMAIN_RESOLUTION_RATE_LIMIT_MAX=30
